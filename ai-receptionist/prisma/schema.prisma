// Prisma schema for the AI Receptionist SaaS.
// Tenant == "Portal" (one client business). Users log in and are scoped to a
// portal (except SUPER_ADMIN, who manages all portals).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CallStatus {
  INIT
  GREETING
  COLLECTING_INFO
  COMPLETED
  FAILED
}

enum Role {
  OWNER
  SUPER_ADMIN
  PORTAL_ADMIN
  CLIENT_USER
  AUDITOR
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

model Tenant {
  id           String        @id @default(cuid())
  name         String
  phoneNumber  String?       @unique
  greeting     String        @default("Thank you for calling. How can I help you today?")
  businessType String        @default("general business")
  notifyEmail  String
  // Per-portal, client-editable guidance appended on top of the AI receptionist's
  // core prompt (business facts + tone). Empty = core behavior only.
  aiInstructions String      @default("")
  theme        Json          @default("{}")
  // Per-portal overrides for GENERIC display words that aren't a record type
  // (e.g. "record", "stage"). Shape: {"record":{"one":"Item","many":"Items"}}.
  // Additive + defaulted; empty means "use the built-in English defaults".
  // Record-type nouns (Contact/Job/...) are NOT stored here — they live on
  // RecordType.label/labelPlural already.
  labels       Json          @default("{}")
  // Booking availability config (open hours, appointment durations, buffer).
  // Stored as JSON like `theme`/`labels`. Empty {} means "use the code defaults"
  // (Mon–Fri 9–5, 30-minute appointments, no buffer), so availability computes
  // correctly before a business configures anything. Shape:
  //   { hours: { mon: [{start:"09:00",end:"17:00"}], ... }, defaultDurationMin,
  //     bufferMin, serviceDurations: { <subtypeKey>: minutes } }
  bookingConfig Json         @default("{}")
  requireEmail Boolean       @default(true)
  // Per-portal on/off switch for the AI Receptionist / Calls feature. NEW portals
  // start OFF (default false); existing portals were backfilled ON by migration.
  receptionistEnabled Boolean @default(false)
  // Per-portal VOICE MODE — the authoritative 3-way choice for the inbound phone
  // experience: "OFF" (decline calls), "WALKIE" (cheap Say/Gather), or "SMOOTH"
  // (premium ElevenLabs ConversationRelay). receptionistEnabled above is kept as
  // an auto-mirror (= voiceMode != "OFF") so existing dashboard/nav gating that
  // reads the boolean keeps working unchanged.
  voiceMode    String        @default("OFF")
  // Which ElevenLabs voice this portal's PREMIUM (ConversationRelay) calls use.
  // One of the five allowed IDs (see src/config/voices.ts); defaults to the
  // original voice so nothing changes for existing portals.
  voiceId      String        @default("uIZsnBL0YK1S5j69bAih")
  // Canonical per-business timezone as a NAMED IANA zone (e.g. "America/New_York"),
  // never a numeric offset, so daylight saving is handled correctly later. Defaults
  // to US Eastern so every existing + new portal has a sane value. FOUNDATION ONLY:
  // nothing reads this yet — it's stored for the future Google Calendar integration
  // (the instant<->wall-clock conversion will key off it). The whole app stays on the
  // zoneless wall-clock model until then; this field changes no current time logic.
  timezone     String        @default("America/New_York")
  status       TenantStatus  @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  contacts     Contact[]
  callSessions CallSession[]
  users        User[]
  savedFilters SavedFilter[]
  exports      ExportRecord[]
  fieldDefs    FieldDef[]
  activity     ActivityLog[]
  templates    EmailTemplate[]
  dashboards   Dashboard[]
  events         Event[]
  resources    Resource[]
  automations    Automation[]
  automationRuns AutomationRun[]
  scheduledJobs  ScheduledJob[]
  inboundEndpoints InboundEndpoint[]
  inboundCalls     InboundCall[]
  recordTypes      RecordType[]
  googleConnection GoogleConnection?
  calendarMaps     ResourceCalendarMap[]
  records          Record[]
  recordLinks      RecordLink[]
  stageHistory     StageHistory[]
  invites          Invite[]
  feedbackTickets  FeedbackTicket[]
  scheduledReports ScheduledReport[]
  communicationSends CommunicationSend[]
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  name             String?
  role             Role      @default(CLIENT_USER)
  tenantId         String?
  tenant           Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  lastLoginAt      DateTime?
  expiresAt        DateTime?
  disabled         Boolean   @default(false)
  signature        String?
  themePrefs       Json      @default("{}")
  contactColumns   Json      @default("{}")
  // When set, effective portal permissions come from this custom role (PortalRole);
  // the base enum `role` still acts as the tier/ceiling reference. Null = use the
  // built-in system-role permissions. Additive, no backfill.
  customRoleId     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  sessions         Session[]
  feedbackTickets  FeedbackTicket[]  @relation("FeedbackSubmitter")
  resolvedFeedback FeedbackTicket[]  @relation("FeedbackResolver")
  feedbackMessages FeedbackMessage[]

  @@index([tenantId])
}

// A per-portal custom user role (a "class"): a named permission set scoped to one
// tenant. `permissions` is an { area: { view/edit/delete } } (or { manage }) map,
// validated against the rights catalog + super-admin ceiling in permissionService.
// Tenant-scoped like FieldDef (bare tenantId, no FK relation) to match existing style.
model PortalRole {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Impersonation overlay (Batch A plumbing). All nullable; NOTHING consumes these
  // yet. When set later, they describe a SUPER_ADMIN "acting as" another user/role,
  // bound to this real session so it's server-revocable and dies with the session.
  impMode          String?   // "view-as-user" | "act-as-type" | null
  impTargetUserId  String?
  impAssumedRole   String?
  impScopeTenantId String?
  impStartedAt     DateTime?

  @@index([userId])
}

// Portal setup invites. A super-admin invites someone (email + role) to a portal;
// the token is the single-use, expiring key the public "create your account" page
// uses to activate a real User with THIS role + tenant (server-authoritative —
// the public page can never choose role/tenant/email). usedAt != null means the
// invite has been consumed (activated) or revoked, so it can never be reused.
model Invite {
  id          String    @id @default(cuid())
  token       String    @unique
  email       String
  name        String?
  role        Role
  // Set when the invite assigns a per-portal custom role: the account is created with
  // base role CLIENT_USER + this customRoleId. Null = a plain system-role invite.
  customRoleId String?
  tenantId    String?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([email])
}

model Contact {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String?
  phone        String?
  // Network-verified inbound caller ID (the number the caller actually called
  // from). SEPARATE from the human-editable `phone` (the spoken/entered callback
  // number) and deliberately NOT unique — two contacts may legitimately share a
  // caller-ID line (family/office). System-set; preserved as the verified origin.
  callerId     String?
  email        String?
  intent       String?
  source       String        @default("unknown")
  customFields Json          @default("{}")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  // Who moved this to the Recycle Bin (captured going forward; NULL for items
  // deleted before this was added — date-only fallback). deletedByType is the
  // category: "user" | "ai" | "sync" | "system".
  deletedBy    String?
  deletedByType String?
  callSessions CallSession[]
  activity     ActivityLog[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

model CallSession {
  id          String     @id @default(cuid())
  callSid     String     @unique
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId   String?
  contact     Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  fromNumber  String
  toNumber    String?
  status      CallStatus @default(INIT)
  transcript  Json       @default("[]")
  extracted   Json       @default("{}")
  turnCount   Int        @default(0)
  emptyCount  Int        @default(0)
  // Backend-owned booking commitment, captured the moment the AI calls the
  // confirm_booking tool (not reconstructed at finalize from the AI's extracted
  // blob). committedAppointmentAt is the SAME zoneless wall-clock string the rest
  // of the app uses ("YYYY-MM-DDTHH:MM") — stored verbatim, never timezone-
  // converted. finalize prefers these over `extracted` when present.
  committedResourceId    String?
  committedAppointmentAt String?
  finalizedAt DateTime?
  emailSentAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId])
}

model SavedFilter {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  view        String   @default("contacts")
  definition  Json     @default("{}")
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model ExportRecord {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scope       String?  // null/"portal" = a portal export; "master" = master-hub; "all" = all-portals
  kind        String   @default("export") // "export" | "import" | "report" — shared history model
  // For kind:"report" runs — which ScheduledReport produced this run. Null for plain
  // exports/imports/backups. SetNull on report delete so run history is preserved.
  reportId    String?
  report      ScheduledReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  dataType    String?  // "contact" | "job" | "booking" | "feedback" | "event" | custom record-type key
  name        String
  rowCount    Int      @default(0)
  okCount     Int?     // import only: rows successfully imported
  failCount   Int?     // import only: rows skipped/failed
  fields      Json     @default("[]")
  csv         String   // export CSV; "" for imports (nothing to download)
  createdById String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([scope])
  @@index([tenantId, kind, dataType])
  @@index([reportId])
}

// A saved, schedulable report definition. FORWARD-COMPATIBLE BY DESIGN: the full
// report spec lives in the opaque `definition` JSON so the builder form can evolve
// next batch with NO migration. Only the columns the list table + scheduler need
// are promoted to real columns. Report RUNS are NOT a second table — they reuse the
// existing ExportRecord history (kind:"report"), downloadable like any export.
model ScheduledReport {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  format      String   @default("csv") // "csv" | "xlsx"
  // Opaque report spec: per-type selected fields + filter rules. Shape finalized
  // next batch — kept as JSON so the form can change without a migration.
  definition  Json     @default("{}")
  // Array of recipient emails (empty for now; populated when delivery lands).
  recipients  Json     @default("[]")
  // Custom rich-text email body (Quill HTML). Null/empty => executor uses the
  // default attachment-notice text. Round-trips through the builder on edit.
  emailBody   String?
  mode        String   @default("immediate") // "immediate" | "recurring"
  // Recurrence spec; null until the recurring scheduler lands (batch 3).
  cadence     Json?
  active      Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastRunAt   DateTime?
  nextRunAt   DateTime?

  // Report runs are ExportRecord rows (kind:"report") — NOT a second history table.
  runs        ExportRecord[]

  @@index([tenantId])
  // Scheduler scan path: find a tenant's active reports that are due to run next.
  @@index([tenantId, active, nextRunAt])
}

model FieldDef {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Which object type this field belongs to. Nullable for safety/back-compat;
  // the backfill points every existing field at its portal's system "contact"
  // record type, and field-creation sets it going forward.
  recordTypeId String?
  recordType   RecordType? @relation(fields: [recordTypeId], references: [id], onDelete: Cascade)
  // Whether the field lives on the record itself or on a relationship (link).
  scope     String   @default("record")
  key       String
  label     String
  type      String   @default("text")
  required  Boolean  @default(false)
  options   Json     @default("[]")
  formula   String?
  order     Int      @default(0)
  // Display-only grouping: which section this field shows under on profiles.
  // Nullable → unassigned fields render under a default "Ungrouped" heading.
  // Never affects the field's key, stored values, or how it's referenced.
  sectionId String?
  system    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, recordTypeId, key])
  @@index([tenantId])
}

// Named, ordered groups for organizing fields on a profile, per record type.
// Display metadata only — a field's section assignment never changes its key,
// its stored values, or how automations/reports/filters reference it.
model FieldSection {
  id           String   @id @default(cuid())
  tenantId     String
  recordTypeId String?
  label        String
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, recordTypeId])
}

// Registry of object types a portal can hold beyond Contact (Job, Policy,
// Work-order, …). The system "contact" type is seeded per portal by the
// backfill. Keys are stable/immutable; labels are freely editable.
model RecordType {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key          String       // stable internal identifier (e.g. "job"); never renamed
  label        String       // editable display label (e.g. "Requisition")
  labelPlural  String?      // editable plural label
  system       Boolean      @default(false) // true for the seeded "contact" type
  stages       Json         @default("[]")  // relationship stages: [{key,label,order}]
  recordStages Json         @default("[]")  // optional record-level lifecycle stages
  subtypes     Json         @default("[]")  // job types + their pipelines: [{key,label,order,stages:[{key,label,order}]}]
  order        Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  fieldDefs    FieldDef[]
  records      Record[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

// An instance of a RecordType (a Job, a Policy, a Work-order). Contacts are NOT
// stored here — they keep their own table. Soft-deletes mirror Contact.
model Record {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recordTypeId String
  recordType   RecordType   @relation(fields: [recordTypeId], references: [id], onDelete: Cascade)
  title        String?
  stageKey     String?      // OPTIONAL record-level lifecycle status
  subtypeKey   String?      // selected subtype (e.g. job type) — picks which pipeline this record uses
  // Appointment date AND time for bookings. A REAL, properly-typed, indexed
  // timestamp (NOT stuffed in the customFields JSON bag) so every future feature
  // — reminders, no-show detection, finding free slots — can query and compare
  // against it. Nullable: only Booking records use it; Jobs/etc. leave it null,
  // so adding the column is harmless to every existing record type. Stored as a
  // full timestamp (date + time of day), mirroring the ScheduledJob.dueAt pattern.
  appointmentAt DateTime?
  // Assigned bookable RESOURCE (staff/stylist/technician). Single-valued typed
  // attribute of a booking — same shape as subtypeKey (service) and stageKey
  // (status), NOT a RecordLink. Nullable: only bookings use it; loose id (the
  // Resource.id) with app-level integrity (delete is blocked while assigned).
  resourceId   String?
  customFields Json         @default("{}")
  // Two-way Google Calendar sync (provenance/ownership). All nullable + additive:
  //   externalSource    "google" = Google-owned (read-only in Clarity); null = Clarity-native.
  //   externalEventId   the Google event/instance id; for a Clarity-owned booking,
  //                     stores the mirror event id after it's pushed out.
  //   externalCalendarId which Google calendar it came from / was pushed to.
  //   externalUpdatedAt  Google's last-updated marker/etag, for idempotent re-sync.
  //   endAt              the REAL end of an external event (arbitrary lengths that
  //                     don't fit the service-duration model). Null for native
  //                     bookings, which keep deriving duration from the service.
  externalSource     String?
  externalEventId    String?
  externalCalendarId String?
  externalUpdatedAt  String?
  endAt              DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  // Who moved this to the Recycle Bin (captured going forward; NULL for items
  // deleted before this was added — date-only fallback). deletedByType is the
  // category: "user" | "ai" | "sync" | "system".
  deletedBy    String?
  deletedByType String?
  links        RecordLink[]

  @@index([tenantId, recordTypeId])
  @@index([tenantId, recordTypeId, deletedAt])
  // Index for date queries/sorting (upcoming bookings, no-show sweeps, free slots).
  @@index([tenantId, recordTypeId, appointmentAt])
  // Per-resource lookups (assigned-booking counts now; resource calendar/lock later).
  @@index([tenantId, resourceId])
  // One Clarity booking per Google event/instance PER RESOURCE (idempotent
  // re-sync upsert). resourceId is in the key so a calendar mapped to several
  // resources blocks each of them (one booking each). Native bookings have the
  // external columns null; Postgres treats NULLs as distinct, so unlimited native
  // rows are allowed — only external rows (all set) are constrained.
  @@unique([tenantId, resourceId, externalCalendarId, externalEventId])
  // Metric-exclusion filter (exclude externalSource="google") + sync scans.
  @@index([tenantId, externalSource])
}

// The many-to-many join between a "parent" and a Record — and the pipeline atom.
// stageKey here is THE relationship stage (a contact can be at different stages
// on different records at once). The parent is polymorphic (parentType/parentId)
// so an Account/Property object can become a parent later with no redesign;
// because it's polymorphic there is intentionally NO DB foreign key on the
// parent (orphan cleanup is handled in code).
model RecordLink {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recordId     String
  record       Record     @relation(fields: [recordId], references: [id], onDelete: Cascade)
  parentType   String     // "contact" now; "account"/"property" later
  parentId     String
  role         String?    // optional: "primary", "candidate", "holder", …
  stageKey     String?    // THE relationship stage
  customFields Json       @default("{}") // per-relationship data
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  stageHistory StageHistory[]

  @@index([tenantId, recordId])
  @@index([tenantId, recordId, stageKey])
  @@index([tenantId, parentType, parentId])
}

// Stage 3a: append-only history of a candidate-job relationship's stage moves.
// One row per move (and one synthetic backfill row per pre-existing link). Lets
// us later answer "how long has this link sat in its current stage?" by reading
// the latest enteredAt for a recordLinkId. NOTHING writes to this on a real move
// yet (that's Stage 3b) and NOTHING reads it for automations yet (Stage 3c).
// Tenant-scoped like everything else; cascades away if the link or portal is removed.
model StageHistory {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recordLinkId String
  recordLink   RecordLink @relation(fields: [recordLinkId], references: [id], onDelete: Cascade)
  fromStage    String?    // stage moved OUT OF (null for the first/backfill entry)
  toStage      String?    // stage moved INTO
  enteredAt    DateTime   @default(now())
  source       String     @default("move") // "move" | "backfill"
  createdAt    DateTime   @default(now())

  @@index([tenantId, recordLinkId, enteredAt])
  @@index([recordLinkId, enteredAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String
  actorType String   @default("user")
  actorId   String?
  actorName String?
  summary   String
  detail    Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([tenantId])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  kind        String   @default("email")
  subject     String?
  body        String   @default("")
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model Dashboard {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  widgets     Json     @default("[]")
  order       Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// ===================== Event-driven automation =====================

// Append-only log of domain events. Decoupled from any consumer: emitters write
// here via the event bus; the automation engine (and future consumers) subscribe.
// `type` is an open string so new event types need no schema change.
model Event {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type        String
  actorType   String   @default("system") // user | system | automation
  actorId     String?
  actorName   String?
  subjectType String   @default("contact")
  subjectId   String?
  payload     Json     @default("{}")
  occurredAt  DateTime @default(now())

  @@index([tenantId, type])
  @@index([tenantId, occurredAt])
  @@index([subjectId])
}

// A workflow: when an event of `triggerType` fires, evaluate `conditions`
// (table.js rule shape) and, if they pass, run `actions` in order.
// conditions/actions are JSON so adding new condition operators or action types
// requires no migration.
model Automation {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  enabled     Boolean         @default(true)
  triggerType String
  conditions  Json            @default("[]")
  actions     Json            @default("[]")
  createdById String?
  // Optional grouping token shared by the two drafts a branching wizard creates
  // (an "(if)" and an "(otherwise)"). Null for every normal/single automation.
  // Used ONLY to visibly link a pair on the list; never affects execution.
  pairId      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  runs        AutomationRun[]

  @@index([tenantId])
  @@index([tenantId, triggerType, enabled])
  @@index([tenantId, pairId])
}

// One row per automation execution attempt — the execution history.
model AutomationRun {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  eventId      String?
  eventType    String
  contactId    String?
  status       String // success | failed | skipped
  matched      Boolean    @default(false)
  results      Json       @default("[]")
  error        String?
  createdAt    DateTime   @default(now())

  @@index([tenantId, createdAt])
  @@index([automationId])
}

// One row per piece of deferred automation work: a delayed action or a
// date-relative scheduled action. The processor (manual button now, host cron
// later) runs rows whose `dueAt` has passed. `action` is a single ActionConfig,
// run via the SAME runAction() the instant engine uses. conditions are evaluated
// before a row is enqueued. `dedupeKey` is unique per tenant so the daily sweep
// can't queue the same occurrence twice (NULL for one-off delays).
model ScheduledJob {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  automationId   String?
  automationName String?
  contactId      String?
  contactName    String?
  action         Json     @default("{}")
  description    String   @default("")
  kind           String   @default("delay") // delay | schedule
  dueAt          DateTime
  status         String   @default("pending") // pending | running | done | failed | canceled
  error          String?
  dedupeKey      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, dedupeKey])
  @@index([tenantId, status, dueAt])
  @@index([tenantId, createdAt])
}

// An inbound webhook endpoint: a public URL (keyed by a secret token) that an
// external system POSTs to in order to create/update a contact in THIS tenant.
// The tenant is derived solely from the token — never from the request body.
model InboundEndpoint {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  token       String        @unique
  mapping     Json          @default("{}") // { incomingJsonKey: crmFieldKey }
  enabled     Boolean       @default(true)
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  calls       InboundCall[]

  @@index([tenantId])
}

// One row per inbound POST attempt, so every call (accepted or rejected) is
// visible and nothing fails silently. Scoped to the same tenant as its endpoint.
model InboundCall {
  id         String          @id @default(cuid())
  tenantId   String
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpointId String
  endpoint   InboundEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  status     String          // accepted | rejected
  reason     String?
  contactId  String?
  sourceIp   String?
  createdAt  DateTime        @default(now())

  @@index([tenantId, createdAt])
  @@index([endpointId, createdAt])
}

// Master-level key/value config (e.g. inviteSenderEmail). One row per setting.
model AppSetting {
  key   String @id
  value String
}

// ---- Feedback / ticketing ----------------------------------------------------
// One model serves BOTH instances. The separator is `tenantId`:
//   - tenantId set  -> a per-portal (tenant-facing) ticket
//   - tenantId null -> a master-hub (admin-facing) ticket
// All visibility/permission rules are enforced server-side; this column only
// keeps the two worlds from ever overlapping in a query.
enum FeedbackStatus {
  OPEN
  RESOLVED
}

model FeedbackTicket {
  id           String         @id @default(cuid())
  tenantId     String?        // null = master-hub ticket
  tenant       Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User           @relation("FeedbackSubmitter", fields: [createdById], references: [id], onDelete: Cascade)
  problem      String
  description  String
  attachments  Json           @default("[]") // list of external link URLs (strings)
  status       FeedbackStatus @default(OPEN)
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?          @relation("FeedbackResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  messages     FeedbackMessage[]

  @@index([tenantId])
  @@index([createdById])
  @@index([status, resolvedAt])
}

model FeedbackMessage {
  id        String         @id @default(cuid())
  ticketId  String
  ticket    FeedbackTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime       @default(now())

  @@index([ticketId])
}

// A bookable RESOURCE: a staff member / stylist / technician / provider, scoped
// per business (tenant). Deliberately a small dedicated table (NOT the records
// backbone): it's a simple config list (name + color), like services — no
// pipeline, subtype, appointment, or custom fields. `color` is stored now for
// the per-resource calendar coloring in a later batch. `order` controls display
// order. `deletedAt` allows soft-archive later without a schema change; this
// batch uses a hard delete that is BLOCKED while any booking is assigned.
model Resource {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  color     String    @default("#6366f1")
  order     Int       @default(0)
  // Optional per-resource weekly hours, same shape as bookingConfig.hours
  // (sun..sat → up to 2 {start,end} windows; [] = closed). NULL = use business hours.
  hours     Json?
  // Optional per-resource per-service durations { subtypeKey: minutes }. NULL/absent
  // key = use the business duration for that service.
  durations Json?
  // Optional per-resource buffer (minutes) between appointments. NULL = use business buffer.
  bufferMin Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  calendarMap ResourceCalendarMap?

  @@index([tenantId])
}

// ONE Google Calendar connection per business (1:1 with Tenant). The owner
// connects once (later sub-batch); this sub-batch only defines storage. Tokens
// are stored ENCRYPTED (AES-256-GCM) — never plaintext, never logged, never
// returned by any GET. Null token columns + status "revoked" = disconnected.
// `status`: "connected" | "revoked" | "error".
model GoogleConnection {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountEmail         String?
  accessTokenEnc       String?
  refreshTokenEnc      String?
  accessTokenExpiresAt DateTime?
  scope                String?
  status               String    @default("connected")
  connectedById        String?
  // Sync-health visibility (two-way sync). Additive + nullable:
  //   lastSyncedAt  when the last successful sync pass completed.
  //   syncStatus    "ok" | "degraded" (null until the first sync).
  //   lastSyncError a short human-readable reason when degraded.
  lastSyncedAt         DateTime?
  syncStatus           String?
  lastSyncError        String?
  // Per-tenant two-way-sync switch. DEFAULT OFF: the sync engine does nothing for
  // a connection until this is flipped true (so it ships dormant in production).
  syncEnabled          Boolean   @default(false)
  // Per-tenant WRITE-OUT (push) switch, independent of read-in. DEFAULT OFF. Push
  // also requires the events write scope (re-consent) before anything is written.
  pushEnabled          Boolean   @default(false)
  // True once the owner has explicitly used the on/off toggle. Auto-enable-on-connect
  // only fires while this is false, so a deliberate "off" is never re-flipped on by
  // saving another calendar mapping.
  syncConfiguredByUser Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// One row per Clarity resource that's mapped to a Google calendar (the hybrid:
// one business connection, many calendar->resource maps). `resourceId` is unique
// so a resource maps to at most one calendar. NOT used by availability this batch.
model ResourceCalendarMap {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resourceId       String   @unique
  resource         Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  googleCalendarId String
  calendarSummary  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
}

// ---- Change Log -------------------------------------------------------------
// Global (non-tenant) product-level log of every change ever shipped to the app.
// Seeded ONCE from git history (see src/db/seedChangelog.ts) and then read by the
// master hub — the running app NEVER reads git. Going forward, each change ships
// its own row as a tiny INSERT migration committed alongside it. `commitSha` is
// unique so seeding/dedup is idempotent (re-running can't create duplicates).
model ChangeLogEntry {
  id          String   @id @default(cuid())
  date        DateTime            // when the change was made (the commit date)
  type        String              // category: Feature / Fix / UI / Backend / Infra / Integration
  description String              // clean, plain-English, user-facing summary
  commitSha   String?  @unique    // source commit hash; null for manually-added rows
  createdAt   DateTime @default(now())

  @@index([date])
}

// One row per MANUAL communication blast (Communication page). Kept deliberately
// minimal/forward-compatible so the Phase-1 Batch-2 "Sent" log can build on it
// (later batches may add body, recipient detail, status, etc.).
model CommunicationSend {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel        String   @default("email") // "email" (texts/surveys later)
  subject        String   @default("")
  // Rich-text body HTML of the blast, persisted so the Sent-log detail view is
  // faithful. Nullable/forward-compatible.
  body           String?
  recipientCount Int      @default(0)
  sentCount      Int      @default(0)
  failCount      Int      @default(0)
  createdById    String?
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
}
