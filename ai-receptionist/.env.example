# ---- REQUIRED (server refuses to boot if any are missing) ----
# For a first look you can leave the Twilio/OpenAI/Resend values as-is:
# placeholder keys automatically switch the app into local "demo mode"
# (mock receptionist + logged emails) so everything works with no accounts.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555550123
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ---- OPTIONAL (sensible defaults shown) ----
OPENAI_MODEL=gpt-4o-mini
RESEND_FROM=onboarding@resend.dev
PORT=3000
TWILIO_VALIDATE_SIGNATURE=false
MAX_TURNS=12
MAX_EMPTY_TURNS=2
AI_MAX_RETRIES=3

# ---- PROVIDER MODE ----
# auto  = use the real service if the key looks real, else a local mock (default)
# mock  = always use the local mock (no OpenAI / Resend calls)
# openai / resend = force the real service
AI_PROVIDER=auto
EMAIL_PROVIDER=auto

# ---- SEED-ONLY (used by `npm run seed`) ----
SEED_NOTIFY_EMAIL=you@yourdomain.com
SEED_BUSINESS_NAME=Acme Services
SEED_BUSINESS_TYPE=home services company
SEED_GREETING=Thanks for calling Acme Services. How can I help you today?

# ---- AUTH / LOGIN (Phase 4) ----
# These are used by `npm run seed` to create your first login accounts,
# and to configure sessions + password-reset links. CHANGE THE PASSWORDS.
SESSION_TTL_HOURS=168
COOKIE_SECURE=false
APP_BASE_URL=http://localhost:3000
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=changeme123
# Optional: the sample client (Portal Admin) login created by the seed
SEED_CLIENT_EMAIL=client@example.com
SEED_CLIENT_PASSWORD=changeme123
