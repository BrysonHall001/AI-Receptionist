# ---- REQUIRED (server refuses to boot if any are missing) ----
# For a first look you can leave the Twilio/OpenAI/Resend values as-is:
# placeholder keys automatically switch the app into local "demo mode"
# (mock receptionist + logged emails) so everything works with no accounts.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555550123
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ---- OPTIONAL (sensible defaults shown) ----
OPENAI_MODEL=gpt-4o-mini
RESEND_FROM=onboarding@resend.dev
# Svix signing secret for Resend delivery webhooks (POST /webhooks/resend).
# OPTIONAL — leave blank to disable webhook ingestion; the endpoint then no-ops.
# Get it from Resend → Webhooks → your endpoint → Signing Secret (starts with whsec_).
RESEND_WEBHOOK_SECRET=
PORT=3000
# TWILIO_VALIDATE_SIGNATURE: verify webhooks really come from Twilio.
# Automatically ON in production; in dev it's off unless set to "true".
TWILIO_VALIDATE_SIGNATURE=false
MAX_TURNS=12
MAX_EMPTY_TURNS=2
AI_MAX_RETRIES=3

# ---- PROVIDER MODE ----
# auto  = use the real service if the key looks real, else a local mock (default)
# mock  = always use the local mock (no OpenAI / Resend calls)
# openai / resend = force the real service
AI_PROVIDER=auto
EMAIL_PROVIDER=auto

# ---- SEED-ONLY (used by `npm run seed`) ----
SEED_NOTIFY_EMAIL=you@yourdomain.com
SEED_BUSINESS_NAME=Acme Services
SEED_BUSINESS_TYPE=home services company
SEED_GREETING=Thanks for calling Acme Services. How can I help you today?

# ---- AUTH / LOGIN (Phase 4) ----
# These are used by `npm run seed` to create your first login accounts,
# and to configure sessions + password-reset links.
# In PRODUCTION (NODE_ENV=production) the seed refuses to run unless
# SUPER_ADMIN_PASSWORD is strong (12+ chars, not "changeme123").
SESSION_TTL_HOURS=168
# COOKIE_SECURE: forces HTTPS-only session cookies. Automatically ON in
# production regardless of this value; keep "false" for local http://localhost.
COOKIE_SECURE=false
APP_BASE_URL=http://localhost:3000
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=changeme123
# Optional: the sample client (Portal Admin) login created by the seed
SEED_CLIENT_EMAIL=client@example.com
SEED_CLIENT_PASSWORD=changeme123

# ---- PRODUCTION HARDENING ----
# Set NODE_ENV=production when deploying. That automatically: enforces HTTPS-only
# cookies, requires Twilio webhook signatures, locks the /internal endpoints
# behind INTERNAL_API_SECRET, and blocks seeding a weak super-admin password.
# NODE_ENV=production
#
# Shared secret protecting the /internal call endpoints in production. Leave
# empty in dev (endpoints stay open locally). In production, /internal is
# disabled unless this is set, and callers must send header x-internal-secret.
INTERNAL_API_SECRET=

# ---- CONVERSATIONRELAY (new, parallel voice path — Stage 1) ----
# ElevenLabs voice spoken on the ConversationRelay path. Defaulted in code to the
# provided voice, so you only set this if you want a different voice.
ELEVENLABS_VOICE_ID=uIZsnBL0YK1S5j69bAih
# Optional: force a specific wss:// URL. Leave blank to auto-derive from the host
# Twilio reaches (recommended). Example: wss://your-app.onrender.com/relay
CONVERSATION_RELAY_WSS_URL=
# ---- GOOGLE CALENDAR (read-only; connection plumbing) ----
# All OPTIONAL — the app boots fine with these blank (Google simply "not set up").
# OAuth client id/secret come from Google Cloud Console (set up in a later sub-batch).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override of the OAuth callback URL. Leave blank to derive it from
# APP_BASE_URL (e.g. http://localhost:3000/api/google/oauth/callback).
GOOGLE_OAUTH_REDIRECT_URL=
# Secret used to AES-256-GCM encrypt stored Google tokens at rest. Any long random
# string works (it's hashed to a 32-byte key). REQUIRED before a token can be
# stored — the storage layer refuses to write a token in plaintext without it.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Stripe (OPTIONAL, test mode). Use a TEST-mode secret key (sk_test_...). Leave blank to run
# without Stripe — billing endpoints will report "Stripe is not configured" until this is set.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (OPTIONAL). From the Stripe Dashboard webhook endpoint
# (or `stripe listen`). Starts with whsec_. Leave blank to disable webhook processing.
STRIPE_WEBHOOK_SECRET=
